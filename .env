# ==============================================================================
# Model Configuration (Ensure these .gguf files are in the ./models directory)
# ==============================================================================

# The reasoning model currently loaded into RAM.
# To switch models, change this value and run `docker compose restart llama-reasoning`

#ACTIVE_MODEL_FILENAME=Qwen2.5-7B-Instruct-Q4_K_M.gguf
#ACTIVE_MODEL_FILENAME=Qwen3-Coder-30B-A3B-Instruct-UD-IQ2_M.gguf
#ACTIVE_MODEL_FILENAME=gemma-4-31B-it-UD-Q2_K_XL.gguf
ACTIVE_MODEL_FILENAME = Qwen3.6-27B-UD-IQ2_XXS.gguf  # this good for general perpous, altho u can upgrate to a 2 bit model
#ACTIVE_MODEL_FILENAME=Qwen3.5-9B.Q4_K_M.gguf   # this is good for general purpose, but you can upgrade to a 2-bit model for better performance


# The embedding model. This runs in a separate lightweight container for RAG.
EMBEDDING_MODEL_FILENAME=bge-small-en-v1.5-q8_0.gguf

# ==============================================================================
# Hardware Optimization (AMD Ryzen 5 7535HS / 16GB RAM)
# ==============================================================================

# Max context window. 48000 is supported but uses ~1.5GB of RAM just for KV cache
CONTEXT_SIZE=8000 #48000

# Offload all layers to Vulkan GPU (AMD Radeon 680M)
GPU_LAYERS=20

# CPU threads fallback (The 7535HS has 8 cores / 16 threads, 8 is a good balance)
THREADS=9

# ==============================================================================
# Open WebUI Security
# ==============================================================================
WEBUI_SECRET_KEY=change-this-to-a-secure-random-string
